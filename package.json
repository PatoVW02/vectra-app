{
  "name": "nerion",
  "version": "1.4.5",
  "description": "Cross-platform disk space analyzer",
  "author": "patovw",
  "email": "hey@patovw.com",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "npm run build:scanner && npm run build && electron-builder",
    "dist:arm64": "npm run build:scanner:arm64 && npm run build && electron-builder --arm64",
    "dist:x64": "npm run build:scanner:x64 && npm run build && electron-builder --x64",
    "dist:universal": "npm run build:scanner:universal && npm run build && electron-builder --universal",
    "dist:win:x64": "npm run build:scanner:win:x64 && npm run build && electron-builder --win nsis --x64",
    "dist:all": "npm run dist:arm64 && npm run dist:x64 && npm run dist:universal",
    "release": "bash scripts/release-mac.sh",
    "release:all": "bash scripts/release-all.sh",
    "typecheck": "tsc --noEmit",
    "build:scanner": "node scripts/build-scanner.mjs",
    "build:scanner:arm64": "node scripts/build-scanner.mjs --target aarch64-apple-darwin --out resources/scanner-bin",
    "build:scanner:x64": "node scripts/build-scanner.mjs --target x86_64-apple-darwin --out resources/scanner-bin",
    "build:scanner:universal": "node scripts/build-scanner.mjs --target aarch64-apple-darwin --out resources/scanner-bin-arm64 && node scripts/build-scanner.mjs --target x86_64-apple-darwin --out resources/scanner-bin-x86_64 && lipo -create resources/scanner-bin-arm64 resources/scanner-bin-x86_64 -output resources/scanner-bin && chmod +x resources/scanner-bin && rm resources/scanner-bin-arm64 resources/scanner-bin-x86_64",
    "build:scanner:win:x64": "node scripts/build-scanner.mjs --target x86_64-pc-windows-msvc --out resources/scanner-bin.exe"
  },
  "dependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron-toolkit/utils": "^4.0.0",
    "electron-updater": "^6.1.0",
    "lucide-react": "^1.8.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  },
  "build": {
    "appId": "com.patricio.nerion",
    "productName": "Nerion",
    "artifactName": "Nerion-${arch}.${ext}",
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.utilities",
      "x64ArchFiles": "scanner-bin",
      "extraResources": [
        {
          "from": "resources/scanner-bin",
          "to": "scanner-bin"
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "extraResources": [
        {
          "from": "resources/scanner-bin.exe",
          "to": "scanner-bin.exe"
        }
      ]
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "icon.png"
      }
    ],
    "directories": {
      "output": "dist"
    },
    "publish": {
      "provider": "github",
      "owner": "PatoVW02",
      "repo": "nerion-app",
      "releaseType": "release"
    }
  }
}
