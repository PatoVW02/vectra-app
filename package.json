{
  "name": "vectra",
  "version": "1.0.8",
  "description": "macOS disk space analyzer",
  "author": "patovw",
  "email": "hey@patovw.com",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "npm run build:scanner && npm run build && electron-builder",
    "typecheck": "tsc --noEmit",
    "build:scanner": "swiftc -O -o resources/scanner-bin resources/scanner/main.swift && chmod +x resources/scanner-bin"
  },
  "dependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron-toolkit/utils": "^4.0.0",
    "electron-updater": "^6.1.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0"
  },
  "build": {
    "appId": "com.patricio.vectra",
    "productName": "Vectra",
    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      { "from": "resources/scanner-bin", "to": "scanner-bin" },
      { "from": "build/icon.png", "to": "icon.png" }
    ],
    "directories": {
      "output": "dist"
    },
    "publish": {
      "provider": "github",
      "owner": "PatoVW02",
      "repo": "vectra-app"
    }
  }
}
